# r5 — PEFT stack + transformers new enough for Qwen3.5 / Gemma3
# docker build -f docker/Dockerfile.unsloth -t llm-finetune/unsloth:cuda12.1.0-r5 .
FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TOKENIZERS_PARALLELISM=false \
    TRANSFORMERS_NO_ADVISORY_WARNINGS=1

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
        git git-lfs curl wget build-essential cmake ninja-build \
        libgomp1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Newer transformers for Qwen3.5 (qwen3_5 arch). No unsloth (breaks torch).
# Explicitly avoid/remove torchao (needs torch.int1 / torch>=2.11).
RUN pip install --upgrade pip setuptools wheel \
 && pip install --no-cache-dir \
      "transformers>=4.51.0,<4.56.0" \
      "tokenizers>=0.21.0" \
      "datasets>=3.0.0" \
      "accelerate>=1.2.0" \
      "peft>=0.14.0,<0.16.0" \
      "trl>=0.14.0,<0.18.0" \
      "bitsandbytes>=0.45.0" \
      "sentencepiece" \
      "protobuf" \
      "scipy" \
      "einops" \
      "packaging" \
      "huggingface_hub" \
      "safetensors" \
      "gguf" \
      "numpy<2.2" \
      "tqdm" \
      "psutil" \
      "tyro" \
      "rich" \
      "markdown-it-py" \
      "pygments" \
      "jinja2" \
      "aiohttp" \
 && pip uninstall -y torchao 2>/dev/null || true

# Keep torch stack from base image (2.5.1+cu121) — do not reinstall newer torch
RUN python -c "import torch; assert torch.__version__.startswith('2.5'), torch.__version__; print(torch.__version__)"

# llama.cpp quantize
RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
 && cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
      -DGGML_CUDA=OFF -DGGML_NATIVE=OFF -DCMAKE_BUILD_TYPE=Release \
 && cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" \
 && (cp /opt/llama.cpp/build/bin/llama-quantize /usr/local/bin/llama-quantize 2>/dev/null \
     || cp /opt/llama.cpp/build/bin/quantize /usr/local/bin/llama-quantize 2>/dev/null \
     || true)

ENV PATH="/opt/llama.cpp/build/bin:${PATH}"

RUN python -c "\
import torch; \
from transformers import TrainingArguments, AutoConfig; \
from peft import LoraConfig; \
from trl import SFTTrainer; \
print('torch', torch.__version__); \
print('SMOKE_OK')"

WORKDIR /workspace
CMD ["bash"]
