# Minimal reliable training image — PEFT/TRL primary (no Unsloth dependency wars)
# Tag: llm-finetune/unsloth:cuda12.1.0-r4
#
# Why no bare `pip install unsloth`:
#   latest unsloth pulls torch>=2.11 / torchao / newest transformers and breaks 2.5.1 stack.
FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TOKENIZERS_PARALLELISM=false \
    TRANSFORMERS_NO_ADVISORY_WARNINGS=1

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
        git git-lfs curl wget build-essential cmake ninja-build \
        libgomp1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Frozen stack compatible with torch 2.5.1 from base image
# DO NOT install unsloth here (it upgrades torch and breaks everything).
RUN pip install --upgrade pip setuptools wheel \
 && pip install --no-cache-dir \
      "transformers==4.46.3" \
      "tokenizers==0.20.3" \
      "datasets==3.2.0" \
      "accelerate==1.2.1" \
      "peft==0.13.2" \
      "trl==0.11.4" \
      "bitsandbytes==0.45.0" \
      "sentencepiece==0.2.0" \
      "protobuf==5.29.2" \
      "scipy==1.14.1" \
      "einops==0.8.0" \
      "packaging" \
      "huggingface_hub==0.27.1" \
      "safetensors==0.4.5" \
      "gguf==0.10.0" \
      "numpy==1.26.4" \
      "tqdm" \
      "psutil" \
      "tyro"

# Remove packages that unsloth/newer HF might have left requiring torch.int1
RUN pip uninstall -y torchao unsloth unsloth_zoo 2>/dev/null || true

# Ensure base torch trio is intact (reinstall only if needed — same versions as image)
RUN python -c "import torch; assert torch.__version__.startswith('2.5.1'), torch.__version__"

# llama.cpp for GGUF export (CPU quantize)
RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
 && cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
      -DGGML_CUDA=OFF -DGGML_NATIVE=OFF -DCMAKE_BUILD_TYPE=Release \
 && cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" \
 && (test -x /opt/llama.cpp/build/bin/llama-quantize \
     && cp /opt/llama.cpp/build/bin/llama-quantize /usr/local/bin/llama-quantize \
     || test -x /opt/llama.cpp/build/bin/quantize \
     && cp /opt/llama.cpp/build/bin/quantize /usr/local/bin/llama-quantize \
     || true)

ENV PATH="/opt/llama.cpp/build/bin:${PATH}"

# Smoke — must succeed
RUN python - <<'PY'
import torch
print("torch", torch.__version__, "cuda_build", torch.version.cuda)
import torchvision
print("torchvision", torchvision.__version__)
from transformers import AutoModelForCausalLM, AutoTokenizer, TrainingArguments
print("transformers OK")
from peft import LoraConfig, get_peft_model
print("peft OK")
from trl import SFTTrainer
print("trl OK")
print("SMOKE_OK")
PY

WORKDIR /workspace
CMD ["bash"]
