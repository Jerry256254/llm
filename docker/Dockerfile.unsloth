# Training image — official PyTorch base (matched CUDA stack)
# Tag used by pipeline: llm-finetune/unsloth:cuda12.1.0-r3
FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TOKENIZERS_PARALLELISM=false

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
        git git-lfs curl wget build-essential cmake ninja-build \
        libgomp1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# HF / training stack (pinned to work with torch 2.5.1)
RUN pip install --upgrade pip setuptools wheel \
 && pip install \
      "transformers==4.46.3" \
      "datasets==3.2.0" \
      "accelerate==1.2.1" \
      "peft==0.13.2" \
      "trl==0.12.2" \
      "bitsandbytes==0.45.0" \
      sentencepiece protobuf scipy einops packaging \
      huggingface_hub hf_transfer gguf numpy tqdm tyro psutil

# Unsloth (best effort)
RUN pip install unsloth || echo "WARN: unsloth install failed"

# ALWAYS re-sync torch stack after unsloth (unsloth often breaks torchvision)
RUN pip install --force-reinstall \
      torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 \
      --index-url https://download.pytorch.org/whl/cu121

RUN pip install xformers==0.0.28.post3 || true

# llama.cpp quant tools (CPU)
RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
 && cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
      -DGGML_CUDA=OFF -DGGML_NATIVE=OFF -DCMAKE_BUILD_TYPE=Release \
 && cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" \
 && (cp /opt/llama.cpp/build/bin/llama-quantize /usr/local/bin/llama-quantize \
     || cp /opt/llama.cpp/build/bin/quantize /usr/local/bin/llama-quantize || true)

ENV PATH="/opt/llama.cpp/build/bin:${PATH}"

# Import smoke (must pass or image is useless)
RUN python -c "import torch, torchvision; \
from transformers import TrainingArguments; \
from peft import LoraConfig; \
print('torch', torch.__version__, 'tv', torchvision.__version__); \
print('SMOKE_OK')"

WORKDIR /workspace
CMD ["bash"]
