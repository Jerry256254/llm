# Training image r4 — PEFT + TRL (stable with torch 2.5.1)
# docker build -f docker/Dockerfile.unsloth -t llm-finetune/unsloth:cuda12.1.0-r4 .
FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-devel

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TOKENIZERS_PARALLELISM=false \
    TRANSFORMERS_NO_ADVISORY_WARNINGS=1

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
        git git-lfs curl wget build-essential cmake ninja-build \
        libgomp1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# All deps for transformers / peft / trl SFTTrainer (incl. rich — required by trl)
RUN pip install --upgrade pip setuptools wheel \
 && pip install --no-cache-dir \
      "transformers==4.46.3" \
      "tokenizers==0.20.3" \
      "datasets==3.2.0" \
      "accelerate==1.2.1" \
      "peft==0.13.2" \
      "trl==0.11.4" \
      "bitsandbytes==0.45.0" \
      "sentencepiece==0.2.0" \
      "protobuf==5.29.2" \
      "scipy==1.14.1" \
      "einops==0.8.0" \
      "packaging" \
      "huggingface_hub==0.27.1" \
      "safetensors==0.4.5" \
      "gguf==0.10.0" \
      "numpy==1.26.4" \
      "tqdm" \
      "psutil" \
      "tyro" \
      "rich" \
      "markdown-it-py" \
      "pygments" \
      "jinja2" \
      "aiohttp"

RUN pip uninstall -y torchao unsloth unsloth_zoo 2>/dev/null || true

# llama.cpp quantize (CPU)
RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
 && cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
      -DGGML_CUDA=OFF -DGGML_NATIVE=OFF -DCMAKE_BUILD_TYPE=Release \
 && cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" \
 && (cp /opt/llama.cpp/build/bin/llama-quantize /usr/local/bin/llama-quantize 2>/dev/null \
     || cp /opt/llama.cpp/build/bin/quantize /usr/local/bin/llama-quantize 2>/dev/null \
     || true)

ENV PATH="/opt/llama.cpp/build/bin:${PATH}"

RUN python -c "\
import torch, torchvision; \
from transformers import TrainingArguments, AutoTokenizer; \
from peft import LoraConfig; \
from trl import SFTTrainer; \
print('torch', torch.__version__); \
print('SMOKE_OK')"

WORKDIR /workspace
CMD ["bash"]
