# Fine-tuning image: Unsloth + TRL + llama.cpp (CPU quantize — fast build)
# Build: docker build -f docker/Dockerfile.unsloth --build-arg CUDA_VERSION=12.1.0 -t llm-finetune/unsloth:cuda12.1.0 .
ARG CUDA_VERSION=12.1.0
FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    CUDA_HOME=/usr/local/cuda \
    HF_HUB_ENABLE_HF_TRANSFER=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev git git-lfs curl wget \
        build-essential cmake ninja-build \
        libgomp1 ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# PyTorch CUDA 12.1 wheels (works with L4 + driver 550+/610)
RUN pip3 install --upgrade pip setuptools wheel \
    && pip3 install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

RUN pip3 install \
        "transformers>=4.44.0" \
        "datasets>=2.19.0" \
        "accelerate>=0.33.0" \
        "peft>=0.12.0" \
        "trl>=0.9.0" \
        "bitsandbytes>=0.43.0" \
        "sentencepiece" \
        "protobuf" \
        "scipy" \
        "einops" \
        "packaging" \
        "hf_transfer" \
        "huggingface_hub"

RUN pip3 install "unsloth[colab-new] @ git+https://github.com/unslothai/unsloth.git" \
    || pip3 install unsloth \
    || echo "WARN: Unsloth install failed; PEFT fallback will be used"

RUN pip3 install xformers \
    || echo "WARN: xformers optional install failed"

# llama.cpp: CPU build only for convert + quantize (minutes, not hours of CUDA compile)
# Training uses PyTorch GPU; GGUF export does not need GGML_CUDA here.
RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
    && cmake -S /opt/llama.cpp -B /opt/llama.cpp/build \
        -DGGML_CUDA=OFF -DGGML_NATIVE=OFF \
        -DCMAKE_BUILD_TYPE=Release \
    && cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" \
    && (cp /opt/llama.cpp/build/bin/llama-quantize /usr/local/bin/llama-quantize \
        || cp /opt/llama.cpp/build/bin/quantize /usr/local/bin/llama-quantize \
        || true) \
    && pip3 install gguf numpy sentencepiece protobuf || true \
    && (test -f /opt/llama.cpp/convert_hf_to_gguf.py \
        || test -f /opt/llama.cpp/convert-hf-to-gguf.py \
        || ls /opt/llama.cpp/*.py | head)

ENV PATH="/opt/llama.cpp/build/bin:${PATH}"

WORKDIR /workspace
CMD ["bash"]
